PORT=3000

# CORS: vergul bilan ajratilgan to‘liq originlar (masalan: https://app.example.com,http://localhost:5173)
# Bo‘sh qoldirilsa — so‘rov origin’i aks ettiriladi (dev va Capacitor uchun qulay).
# Production’da frontend domenlaringizni aniq ko‘rsating.
# CORS_ORIGINS=
JWT_SECRET=elektrolearn-dev-secret
JWT_EXPIRES_IN=12h

# Print startup banner (WARNING: can expose secrets)
# true = masked secrets, full = show everything
SHOW_BOOT_INFO=true

# If you have a public domain, set it (example: https://api.example.com)
PUBLIC_DOMAIN=

# Local Postgres
DATABASE_URL=postgresql://sarvarbekxazratov@localhost:5432/elektrolearn

# Refresh token settings
REFRESH_TOKEN_DAYS=30

# Default seeded superadmin (MVP)
SUPERADMIN_EMAIL=elektroLearn@admin.com
SUPERADMIN_PASSWORD=!Qw3rty
